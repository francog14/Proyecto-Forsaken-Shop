###########################################################
# 1. CATEGORIA - Puerto 7070
###########################################################

### Listar categorias
GET http://localhost:7070/categorias
Content-Type: application/json

### Buscar categoria por ID
GET http://localhost:7070/categorias/1
Content-Type: application/json

### Crear categoria
POST http://localhost:7070/categorias
Content-Type: application/json

{
  "nombre_categoria": "Poleras"
}

### Actualizar categoria
PUT http://localhost:7070/categorias
Content-Type: application/json

{
  "id_categoria": 1,
  "nombre_categoria": "Poleras premium"
}

### Eliminar categoria
DELETE http://localhost:7070/categorias/1
Content-Type: application/json

