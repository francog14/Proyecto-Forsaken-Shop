###########################################################
# 8. PEDIDO - Puerto 7080
###########################################################

### Listar pedidos
GET http://localhost:7080/pedidos
Content-Type: application/json

### Buscar pedido por ID
GET http://localhost:7080/pedidos/1
Content-Type: application/json

### Buscar pedidos por RUT
GET http://localhost:7080/pedidos/rut/12345678-9
Content-Type: application/json

### Buscar pedidos por usuario
GET http://localhost:7080/pedidos/usuario/1
Content-Type: application/json

### Crear pedido
POST http://localhost:7080/pedidos
Content-Type: application/json

{
  "id_usuario": 1,
  "id_venta": 1,
  "rut_cliente": "12345678-9",
  "estado": "PAGADO",
  "fecha_pedido": "2026-06-12"
}

### Actualizar pedido completo
PUT http://localhost:7080/pedidos
Content-Type: application/json

{
  "id_pedido": 1,
  "id_usuario": 1,
  "id_venta": 1,
  "rut_cliente": "12345678-9",
  "estado": "EN_PREPARACION",
  "fecha_pedido": "2026-06-12"
}

### Actualizar estado de pedido
PUT http://localhost:7080/pedidos/1/estado
Content-Type: application/json

{
  "estado": "ENTREGADO"
}

### Eliminar pedido
DELETE http://localhost:7080/pedidos/1
Content-Type: application/json

